FROM node:22-slim AS builder

WORKDIR /app
COPY portal-frontend/package.json portal-frontend/package-lock.json* ./
RUN npm install

COPY portal-frontend/ ./
RUN npm run build

FROM node:22-slim

RUN npm install -g serve@14

WORKDIR /app
COPY --from=builder /app/dist ./dist

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
